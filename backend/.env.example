# Cloudflare API credentials
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_account_id_here

# Admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional: secret for signing session cookies (recommended in production).
# If empty, a key is derived from ADMIN_PASSWORD.
# SESSION_SECRET=

# Server port
LISTEN_PORT=3000